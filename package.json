{
  "name": "tbh-fan-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "build:static-data": "node scripts/build-static-seo-data.mjs",
    "preview": "npm run build:static-data && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run upload:runtime-v2 && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "npm run upload:runtime-v2 && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "normalize": "node scripts/normalize-game-data.mjs",
    "market:fetch": "node scripts/fetch-steam-market.mjs",
    "audit:competitor": "node scripts/audit-competitor-coverage.mjs",
    "audit:data-gaps": "node scripts/audit-data-gaps.mjs",
    "competitor:fetch": "node scripts/fetch-competitor-public-data.mjs",
    "competitor:normalize": "node scripts/build-competitor-normalized.mjs",
    "enrich:data": "node scripts/build-enriched-data.mjs",
    "graph:build": "node scripts/build-graph-index.mjs",
    "upload:r2": "npm run build:static-data && node scripts/upload-r2.mjs",
    "upload:runtime-v2": "npm run build:static-data && node scripts/upload-runtime-v2.mjs",
    "upload:worker-data": "node scripts/upload-worker-data.mjs",
    "deploy:worker": "npm run deploy",
    
    "verify:pages": "node scripts/verify-pages.mjs",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "check:locale-links": "node scripts/check-locale-links.mjs",
    "prebuild": "npm run check:mojibake && npm run build:static-data",
    "lint": "npm run check:locale-links && eslint"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "fuse.js": "^7.4.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "undici": "^8.3.0",
    "wrangler": "^4.97.0"
  }
}
